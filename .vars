#!/bin/bash

export PATH=$HOME/Applications:$HOME/.bin:$HOME/.scripts/bin:/usr/local/bin:$PATH

export TERMCMD=alacritty
export TERM=alacritty
export BROWSER=firefox
export EDITOR="$(if ! command -v nvim &> /dev/null; then echo 'vim'; else echo 'nvim'; fi)"
export SVDIR=$HOME/.service

export SSH_KEY_PATH="~/.ssh/dsa_id"
export XDG_CONFIG_HOME="$HOME/.config"
export QT_QPA_PLATFORMTHEME=qt5ct
export _JAVA_AWT_WM_NONREPARENTING=1
export LC_ALL="en_US.UTF-8"
export GPG_TTY=$(tty)

export PLATFORM_SDK_ROOT=/home/void/Aurora/psdk
export PLATFORM_SDK_OPENFORTIVPN_CONF=/home/$USER/.config/PlatformSDK/openfortivpn_config

# --- Scripts specific ---
export FINDCMD="fd --hidden --absolute-path ."
export GREPCMD="rg --with-filename --no-heading --max-filesize=500M --maxdepth=5 ."
export DMENUCMD="rofi -dmenu -i"
export FZFCMD="fzf"
export CRIT_NOTIFICATION_HOLD=8000
